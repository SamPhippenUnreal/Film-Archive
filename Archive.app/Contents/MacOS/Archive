#!/bin/bash
# Archive — macOS Dock / Finder launcher.
#
# Clicking the icon runs this. It opens the app exactly like the terminal
# command does, but because a Dock launch has no console, it records
# everything to  data/dock-launch.log  and shows a dialog if anything goes
# wrong — so a failure is visible instead of "nothing happens".
#
# This executable sits at:
#   <project root>/Archive.app/Contents/MacOS/Archive
# so the project root is three directories up. Nothing here is hardcoded.

HERE="$(cd "$(dirname "$0")" && pwd)"        # …/Archive.app/Contents/MacOS
ROOT="$(cd "$HERE/../../.." && pwd)"          # the folder that contains the .app
cd "$ROOT" || exit 1

mkdir -p data
LOG="$ROOT/data/dock-launch.log"

{
    echo
    echo "======== $(date '+%Y-%m-%d %H:%M:%S')  Dock launch ========"
    echo "root: $ROOT"
    echo "PATH: $PATH"
} >>"$LOG" 2>&1

if [ ! -x ".venv/bin/python" ]; then
    echo "the environment (.venv) is missing" >>"$LOG"
    /usr/bin/osascript -e 'display dialog "Archive is not set up yet.\n\nOpen Terminal in the Archive folder and run:\n\n    ./setup.sh" buttons {"OK"} default button 1 with title "Archive"' >/dev/null 2>&1
    open "$ROOT" >/dev/null 2>&1
    exit 1
fi

# Run the very same updater/launcher the terminal uses, capturing all output.
# (Calling Python directly avoids depending on another script's +x bit.)
".venv/bin/python" update_and_launch.py "$@" >>"$LOG" 2>&1
status=$?
echo "exit status: $status" >>"$LOG"

if [ "$status" -ne 0 ]; then
    /usr/bin/osascript -e 'display dialog "Archive could not start.\n\nSee  data/dock-launch.log  in the Archive folder for details." buttons {"OK"} default button 1 with title "Archive"' >/dev/null 2>&1
fi
exit "$status"
