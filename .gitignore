# ── Local Python environment (rebuilt by setup.cmd) ──────────────
.venv/
venv/
env/
ENV/

# ── Python bytecode / caches ─────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/

# ── Archive local cache (regenerates itself) ─────────────────────
# Thumbnails, TIFF previews, the photo index and colour cache — all
# machine-local and rebuildable. Never needs to be shared.
data/

# ── Your private, machine-specific settings ──────────────────────
# Holds YOUR real archive path. Copy archive.config.example.json
# to this name and edit it; it stays out of git.
archive.config.json

# ── Runtime logs ─────────────────────────────────────────────────
*.log

# ── Editor / tooling (local, not part of the app) ────────────────
.claude/
.vscode/
.idea/
*.swp
*~

# ── OS junk ──────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# ── Generated Windows taskbar shortcut ───────────────────────────
# Created per-machine by setup.cmd / make_shortcut.ps1. Holds absolute
# local paths (to .venv and the icon), so it is never committed.
*.lnk

# ── Misc ─────────────────────────────────────────────────────────
*.tmp
*.bak
